# OpenClaw Docker deployment
#
# Project name must use lowercase English letters only.
# setup.sh derives these values from it automatically:
# - Compose project name: openclaw-<name>
# - Gateway container: openclaw-gateway-<name>
# - CLI container: openclaw-cli-<name>
# - Host data dir: /data/openclaw-<name>
OPENCLAW_PROJECT_NAME=koala

# Gateway auth token
OPENCLAW_GATEWAY_TOKEN=1234567890

# Network ports
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Timezone
OPENCLAW_TZ=Asia/Shanghai
